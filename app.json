{
  "expo": {
    "name": "Travel Diary",
    "slug": "device-features-react-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Travel Diary to capture photos for your travel journal.",
          "recordAudioAndroid": false,
          "barcodeScannerEnabled": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Travel Diary to choose photos from your library for travel stamps.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Travel Diary to read photo metadata for travel stamps.",
          "savePhotosPermission": false,
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": ["photo"]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Travel Diary to attach your current address to each saved entry."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "travel-entry-saves"
        }
      ]
    ]
  }
}
